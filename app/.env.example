# Copy to app/.env and fill in values. Never commit .env.

# Use bundled demo JSON in the UI (default true). Set false for an empty/real PostgreSQL
# database: reads chart, studio profile, ledger, trial balance, and templates from the DB.
USE_SAMPLE_DATA=true

# PostgreSQL (used when USE_SAMPLE_DATA=false)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=moth_and_money
DB_USER=postgres
DB_PASSWORD=

# Optional: overrides discrete DB_* if set (e.g. postgres://user:pass@host:5432/dbname)
# DATABASE_URL=
